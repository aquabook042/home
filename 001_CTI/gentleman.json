    {
      "type": "malware",
      "spec_version": "2.1",
      "id": "malware--b2c3d4e5-f6a7-8901-bcde-234567890abc",
      "created": "2026-06-25T00:00:00.000Z",
      "modified": "2026-06-25T00:00:00.000Z",
      "name": "Gentlemen Ransomware",
      "description": "Golang-based cross-platform ransomware encryptor. Requires an 8-byte password parameter at runtime as an anti-analysis measure. Appends .7mtzhh or .ojuopo extension to encrypted files and drops README-GENTLEMEN.txt ransom notes. Self-propagating via SMB and GPO.",
      "malware_types": ["ransomware"],
      "is_family": false,
      "architecture_execution_envs": ["x86-64"],
      "implementation_languages": ["go"],
      "capabilities": ["encrypts-files", "exfil-data", "kills-av-software", "self-propagates"],
      "labels": ["ransomware", "golang", "cross-platform"]
    },
    {
      "type": "malware",
