      "id": "vulnerability--a7b8c9d0-e1f2-3456-0123-7890abcdef01",
      "created": "2026-06-25T00:00:00.000Z",
      "modified": "2026-06-25T00:00:00.000Z",
      "name": "CVE-2024-55591",
      "description": "Critical authentication bypass vulnerability in Fortinet FortiOS and FortiProxy. Allows an unauthenticated attacker to gain super_admin privileges via specially crafted WebSocket requests exploiting a race condition and missing credential validation. The Gentlemen maintain a database of ~14,700 already-compromised FortiGate devices.",
      "external_references": [
        {
          "source_name": "cve",
          "external_id": "CVE-2024-55591"
        }
      ]
    },
