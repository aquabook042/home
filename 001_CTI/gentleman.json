      "modified": "2026-06-25T00:00:00.000Z",
      "name": "ThrottleBlood.sys",
      "description": "Custom BYOVD (Bring Your Own Vulnerable Driver) derived from ThrottleStop.sys. Exploited by All.exe and Allpatch2.exe to gain kernel privileges and terminate EDR/AV processes.",
      "malware_types": ["rootkit"],
      "is_family": false,
      "labels": ["byovd", "av-killer", "kernel-driver"]
    },
