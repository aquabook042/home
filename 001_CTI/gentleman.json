      "id": "threat-actor--a1b2c3d4-e5f6-7890-abcd-1234567890ab",
      "created": "2026-06-25T00:00:00.000Z",
      "modified": "2026-06-25T00:00:00.000Z",
      "name": "The Gentlemen",
      "description": "The Gentlemen is a Ransomware-as-a-Service (RaaS) operation that emerged in mid-2025. The group conducts double-extortion attacks — encrypting victim files and threatening to publish stolen data. The ransomware binary is written in Golang and targets Windows, Linux, ESXi, NAS, and BSD environments. Suspected to operate from Russian-speaking regions based on a prohibition against targeting CIS countries.",
      "threat_actor_types": ["crime-syndicate"],
      "aliases": ["Gentleman", "Gentlemen RaaS", "Hastalamuerte"],
      "first_seen": "2025-08-01T00:00:00.000Z",
      "last_seen": "2026-05-28T00:00:00.000Z",
      "sophistication": "advanced",
      "resource_level": "organization",
      "primary_motivation": "financial-gain",
      "secondary_motivations": ["organizational-gain"],
      "goals": ["Financial gain via ransomware and data extortion"],
      "labels": ["ransomware", "raas", "double-extortion"],
